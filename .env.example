# ---------- LLM ----------
LLM_BACKEND=ollama          # or "vllm"
OLLAMA_URL=http://localhost:11434/api/generate
VLLM_URL=http://localhost:8000/v1/chat/completions
VLLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct   # change to a smaller model if needed

# ---------- Speech ----------
WHISPER_MODEL=/usr/share/whisper/models/ggml-base.en.bin   # path to Whisper.cpp model

# ---------- TTS ----------
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC   # Coqui TTS model (downloads on first run)
